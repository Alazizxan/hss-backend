generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

model User {
  id           String @id @default(uuid())
  username     String @unique
  email        String @unique
  passwordHash String

  xp           Int @default(0)
  level        Int @default(1)

  role         Role @default(USER)

  isPremium    Boolean @default(false)
  premiumUntil DateTime?

  progress     UserProgress[]
  userCourseAccess UserCourseAccess[]   // 👈 ADD SHU
  hackerChats HackerRoomChat[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Course {
  id          String  @id @default(uuid())
  title       String
  description String
  thumbnail   String?
  isPremium   Boolean @default(false)
  xpReward    Int     @default(100)

  category    String   @default("cybersecurity")
  level       String   @default("beginner") // beginner | junior | middle | senior

  PremiumCodes PremiumCode[]

  sections Section[]

  userCourseAccess UserCourseAccess[]   // 👈 ADD SHU

 


  createdAt DateTime @default(now())
}

model Section {
  id    String @id @default(uuid())
  title String
  order Int

  courseId String
  course   Course @relation(fields: [courseId], references: [id])

  lessons Lesson[]
}

model Lesson {
  id          String  @id @default(uuid())
  title       String
  description String?

  type     String // TEXT | VIDEO | IMAGE
  content  String?
  videoUrl String?
  imageUrl String?

  xpReward Int @default(10)
  order    Int
  quiz Quiz?

  sectionId String
  section   Section @relation(fields: [sectionId], references: [id])
}

model UserProgress {
  id String @id @default(uuid())

  userId   String
  user     User @relation(fields: [userId], references: [id])

  courseId String
  lessonId String

  completed Boolean @default(false)
  xpEarned  Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, lessonId])
}

model PremiumCode {
  id        String   @id @default(uuid())
  code      String   @unique

  courseId  String
  course    Course   @relation(fields: [courseId], references: [id])

  isUsed    Boolean  @default(false)

  createdAt DateTime @default(now())
}

model UserCourseAccess {
  id String @id @default(uuid())

  userId   String
  user     User   @relation(fields: [userId], references: [id])

  courseId String
  course   Course @relation(fields: [courseId], references: [id])

  type String // CODE | ADMIN

  createdAt DateTime @default(now())

  @@unique([userId, courseId])
}

model UserCourseCompletion {
  id        String @id @default(uuid())
  userId    String
  courseId  String

  rewarded  Boolean @default(false)

  createdAt DateTime @default(now())

  @@unique([userId, courseId])
}


model Quiz {
  id       String @id @default(uuid())
  title    String

  lessonId String @unique
  lesson   Lesson @relation(fields: [lessonId], references: [id])

  questions Question[]

  createdAt DateTime @default(now())
}

model Question {
  id      String @id @default(uuid())
  text    String

  quizId  String
  quiz    Quiz   @relation(fields: [quizId], references: [id])

  options Option[]
}

model Option {
  id         String @id @default(uuid())
  text       String
  isCorrect  Boolean @default(false)

  questionId String
  question   Question @relation(fields: [questionId], references: [id])
}

model QuizResult {
  id        String @id @default(uuid())

  userId    String
  quizId    String

  score     Int
  passed    Boolean

  createdAt DateTime @default(now())

  @@unique([userId, quizId])
}




model QuizAttempt {
  id String @id @default(uuid())

  userId String
  quizId String

  score Int
  passed Boolean

  createdAt DateTime @default(now())
}


model HackerRoomMessage {
  id String @id @default(uuid())

  userId String

  role String
  content String

  createdAt DateTime @default(now())
}


model HackerRoomChat {
  id        String   @id @default(uuid())

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  role      String // USER | ASSISTANT

  message   String   @db.Text

  createdAt DateTime @default(now())
}


model Certificate {
  id String @id @default(uuid())

  userId String
  courseId String

  verifyToken String @unique @default(uuid())

  createdAt DateTime @default(now())

  @@unique([userId, courseId])
}